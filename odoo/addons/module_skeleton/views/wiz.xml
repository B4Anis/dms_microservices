<odoo>

    <record id="view_module_skeleton_some_action_wiz" model="ir.ui.view">
        <field name="name">New Customer Call</field>
        <field name="model">module.skeleton.some.action.wiz</field>
        <field name="arch" type="xml">
			<form>
				<group>
						<field name="skeleton_id"  readonly="1"  />		
						<field name="message"  required="1"/>	
				</group>
				<footer>
					<button name="action_process" string="Process ...." type="object" default_focus="1" class="oe_highlight"/>
					<button string="Annuler" class="btn btn-default" special="cancel" />
				</footer>
			</form>
        </field>
    </record> 
    


	   
</odoo>
