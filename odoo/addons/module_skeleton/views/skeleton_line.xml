<odoo>
	  	  
        <record id="view_erpish_skeleton_line_tree" model="ir.ui.view">
            <field name="name">erpish.cahsier.exepnses.tree</field>
            <field  name="model">module.skeleton.line</field>  
            <field name="arch" type="xml">
                <tree editable="bottom" create="1">
					<field name="name"/>
					<field name="skeleton_id" invisible="1" />
                </tree>
            </field>
        </record>
	          
        <record id="action_skeleton_line" model="ir.actions.act_window">
            <field name="name">Skeleton Lines</field>
            <field name="res_model">module.skeleton.line</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">tree</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>                   
        </record>	         
        	  
</odoo>
