<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================
             CATEGORY VIEWS
        ============================================================ -->

        <record id="view_ensia_dms_category_tree" model="ir.ui.view">
            <field name="name">ensia.dms.category.tree</field>
            <field name="model">ensia.dms.category</field>
            <field name="arch" type="xml">
                <tree string="Categories">
                    <field name="name"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record id="view_ensia_dms_category_form" model="ir.ui.view">
            <field name="name">ensia.dms.category.form</field>
            <field name="model">ensia.dms.category</field>
            <field name="arch" type="xml">
                <form string="Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ensia_dms_category" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">ensia.dms.category</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ============================================================
             DEPARTMENT VIEWS
        ============================================================ -->

        <record id="view_ensia_dms_department_tree" model="ir.ui.view">
            <field name="name">ensia.dms.department.tree</field>
            <field name="model">ensia.dms.department</field>
            <field name="arch" type="xml">
                <tree string="Departments">
                    <field name="name"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <record id="view_ensia_dms_department_form" model="ir.ui.view">
            <field name="name">ensia.dms.department.form</field>
            <field name="model">ensia.dms.department</field>
            <field name="arch" type="xml">
                <form string="Department">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                        <group string="Assigned Users">
                            <field name="user_ids" widget="many2many_tags" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_ensia_dms_department" model="ir.actions.act_window">
            <field name="name">Departments</field>
            <field name="res_model">ensia.dms.department</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- ============================================================
             DOCUMENT VIEWS
        ============================================================ -->

        <!-- List view -->
        <record id="view_ensia_dms_document_tree" model="ir.ui.view">
            <field name="name">ensia.dms.document.tree</field>
            <field name="model">ensia.dms.document</field>
            <field name="arch" type="xml">
                <tree string="Documents" decoration-muted="not category_id">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="department_ids" widget="many2many_tags"/>
                </tree>
            </field>
        </record>

        <!-- Form view (with chatter for attachments) -->
        <record id="view_ensia_dms_document_form" model="ir.ui.view">
            <field name="name">ensia.dms.document.form</field>
            <field name="model">ensia.dms.document</field>
            <field name="arch" type="xml">
                <form string="Document">
                    <header/>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Document Name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Classification">
                                <field name="category_id"/>
                            </group>
                            <group string="Departments">
                                <field name="department_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Kanban view -->
        <record id="view_ensia_dms_document_kanban" model="ir.ui.view">
            <field name="name">ensia.dms.document.kanban</field>
            <field name="model">ensia.dms.document</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="category_id">
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="department_ids"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <field name="department_ids" widget="many2many_tags"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_ensia_dms_document_search" model="ir.ui.view">
            <field name="name">ensia.dms.document.search</field>
            <field name="model">ensia.dms.document</field>
            <field name="arch" type="xml">
                <search string="Search Documents">
                    <field name="name" string="Document" filter_domain="[('name', 'ilike', self)]"/>
                    <field name="category_id"/>
                    <field name="department_ids"/>

                    <!-- Filters -->
                    <filter string="No Category" name="filter_no_category"
                            domain="[('category_id', '=', False)]"/>
                    <separator/>
                    <filter string="My Departments" name="filter_my_departments"
                            domain="[('department_ids.user_ids', 'in', [uid])]"/>

                    <!-- Group By -->
                    <group string="Group By" expand="0">
                        <filter string="Category" name="groupby_category"
                                context="{'group_by': 'category_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_ensia_dms_document" model="ir.actions.act_window">
            <field name="name">Documents</field>
            <field name="res_model">ensia.dms.document</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="search_view_id" ref="view_ensia_dms_document_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first document
                </p>
                <p>
                    Use documents to organise your files by department and category.
                </p>
            </field>
        </record>

        <!-- ============================================================
             MENUS
        ============================================================ -->

        <!-- Top-level "Documents" app menu -->
        <menuitem id="menu_ensia_dms_root"
                  name="Documents"
                  sequence="50"
                  web_icon="mail,static/description/icon.png"/>

        <!-- Main document list -->
        <menuitem id="menu_ensia_dms_documents"
                  name="Documents"
                  parent="menu_ensia_dms_root"
                  action="action_ensia_dms_document"
                  sequence="10"/>

        <!-- Configuration sub-menu -->
        <menuitem id="menu_ensia_dms_config"
                  name="Configuration"
                  parent="menu_ensia_dms_root"
                  sequence="90"
                  groups="ensia_dms.group_dms_manager"/>

        <menuitem id="menu_ensia_dms_categories"
                  name="Categories"
                  parent="menu_ensia_dms_config"
                  action="action_ensia_dms_category"
                  sequence="10"/>

        <menuitem id="menu_ensia_dms_departments"
                  name="Departments"
                  parent="menu_ensia_dms_config"
                  action="action_ensia_dms_department"
                  sequence="20"/>

    </data>
</odoo>
